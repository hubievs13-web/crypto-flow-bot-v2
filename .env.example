# crypto-flow-bot-v2 deployment variables.
# Keep real secrets out of git.

CONFIG_PATH=config.yaml

# Telegram alerts. Required only when config.yaml has telegram.enabled: true.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Safe default: false loads config/logging and exits without fetching market data.
# Set true for the live Telegram-only runner.
LIVE_RUNNER_ENABLED=false
LIVE_CYCLE_INTERVAL_SECONDS=900
LIVE_RUNNER_MAX_CYCLES=

# Keeps virtual positions in a JSON file. Mount /app/data as a persistent volume for production.
POSITION_STATE_PATH=/app/data/positions.json
