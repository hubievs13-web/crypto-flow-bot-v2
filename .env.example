# crypto-flow-bot-v2 deployment variables.
# Keep real secrets out of git.
# Defaults are safe: no live loop and no Telegram credentials.

CONFIG_PATH=config.yaml

# Live runner. Leave false for local validation / safe startup.
# Set LIVE_RUNNER_ENABLED=true only when config.yaml and Telegram credentials are ready.
LIVE_RUNNER_ENABLED=false
LIVE_RUNNER_INTERVAL_SECONDS=900
LIVE_RUNNER_MAX_CYCLES=

# Legacy interval variable accepted by older deployments. Prefer LIVE_RUNNER_INTERVAL_SECONDS.
LIVE_CYCLE_INTERVAL_SECONDS=

# Telegram alerts. Default config reads TELEGRAM_CHAT_ID.
# TELEGRAM_CHAT_ID may contain one chat ID or a comma-separated list.
# To use TELEGRAM_CHAT_IDS instead, set telegram.chat_id_env: TELEGRAM_CHAT_IDS in config.yaml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_IDS=

# Virtual position state. Relative paths resolve from the application working directory.
POSITION_STATE_PATH=data/positions.json
