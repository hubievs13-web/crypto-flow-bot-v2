# crypto-flow-bot-v2 Railway deployment variables.
# Keep real secrets out of git.

CONFIG_PATH=config.yaml

# Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Enable the live Telegram-only runner on Railway.
LIVE_RUNNER_ENABLED=true
LIVE_CYCLE_INTERVAL_SECONDS=900
LIVE_RUNNER_MAX_CYCLES=

# Optional: keeps virtual positions in a JSON file while the container is alive.
# Add a Railway Volume later if you need this to persist across redeploys/restarts.
POSITION_STATE_PATH=/app/data/positions.json
