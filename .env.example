# PR 11 still uses only public Binance Futures market-data endpoints.
# Keep real secrets out of git.

CONFIG_PATH=config.yaml

# Telegram is used only when telegram.enabled=true in config.yaml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live runner is disabled unless explicitly enabled.
LIVE_RUNNER_ENABLED=false
LIVE_CYCLE_INTERVAL_SECONDS=900
LIVE_RUNNER_MAX_CYCLES=

# Persistent virtual-position state. This file is runtime data, not source code.
POSITION_STATE_PATH=data/positions.json
